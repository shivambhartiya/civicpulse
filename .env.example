# CivicPulse Environment Variables
# Copy this file to .env.local. Never commit .env.local.

# Gemini AI
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Google Maps Platform
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_ID=

# App config
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=CivicPulse

# Optional. Generated and stored automatically when omitted.
APP_SECRET=

# Optional. Defaults to .civicpulse-data in the project directory.
CIVICPULSE_DATA_DIR=

# Optional map defaults. Used when no user-specific ward center is available.
NEXT_PUBLIC_DEFAULT_CITY_LAT=
NEXT_PUBLIC_DEFAULT_CITY_LNG=
