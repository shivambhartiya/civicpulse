# Gemini AI - enough for AI features
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Free maps use OpenStreetMap/Leaflet and do not require an API key.

# Local Firebase Emulator mode - no Google/Firebase account required
NEXT_PUBLIC_USE_FIREBASE_EMULATORS=true
NEXT_PUBLIC_FIREBASE_API_KEY=demo-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=demo-civicpulse.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=demo-civicpulse
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=demo-civicpulse.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:demo
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# App config
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000
NEXT_PUBLIC_APP_NAME=CivicPulse
APP_SECRET=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# Optional production Firebase Admin values, only needed for a hosted Firebase project
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=
GCS_BUCKET_NAME=demo-civicpulse.appspot.com
